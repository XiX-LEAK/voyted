# =============================================================================
# Voyted — Variables d'environnement
# =============================================================================
# Copier ce fichier : cp .env.example .env

# --- Google OAuth ---
# Créer une app sur https://console.cloud.google.com
# Ajouter redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- NextAuth ---
# Générer avec: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here
AUTH_URL=http://localhost:3000

# --- Database (valeurs par défaut docker-compose) ---
# POSTGRES_USER=vinuser
# POSTGRES_PASSWORD=vinpassword
# POSTGRES_DB=vintrack

# --- Worker ---
# CHECK_INTERVAL_MS=1500
# PROXY_FILE=proxies.txt
